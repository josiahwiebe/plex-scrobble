# Local / Vercel: copy to `.env` (Vite and the server read these in dev).

# Postgres (Supabase or any host; use a pooler URL in production if your host recommends it).
DATABASE_URL=""

# Plex OAuth
PLEX_CLIENT_ID=""
PLEX_REDIRECT_URI="http://localhost:5173/auth/plex/callback"

# Encryption & sessions
ENCRYPTION_SECRET=""
SESSION_SECRET=""

# Telegram (optional)
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# Optional: Cloudflare Worker (Browser Rendering) for Letterboxd when server fetch hits a challenge.
# Deploy workers/letterboxd-browser — same secret on Worker and here.
LETTERBOXD_BROWSER_RENDERING_URL=""
LETTERBOXD_BROWSER_RENDERING_SECRET=""
