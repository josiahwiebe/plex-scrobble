# Local / Vercel: copy to `.env` (Vite and the server read these in dev).

# Postgres (Supabase or any host; use a pooler URL in production if your host recommends it).
DATABASE_URL=""

# Plex OAuth
PLEX_CLIENT_ID=""
PLEX_REDIRECT_URI="http://localhost:5173/auth/plex/callback"

# Encryption & sessions
ENCRYPTION_SECRET=""
SESSION_SECRET=""

# Telegram (optional)
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# Letterboxd login fallback uses Puppeteer (@sparticuz/chromium on Vercel). No extra env vars required.
# Optional legacy: Cloudflare Browser Rendering worker (workers/letterboxd-browser) — not used by default.
# LETTERBOXD_BROWSER_RENDERING_URL=""
# LETTERBOXD_BROWSER_RENDERING_SECRET=""
